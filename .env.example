# Copy this file to .env and customise before running docker compose up.
# Never commit .env — it is listed in .gitignore.

# Whisper STT
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM via LM Studio (must be running on the host machine)
LM_STUDIO_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b
LLM_MAX_HISTORY=8

# Child's name used in the bot's personality prompt
CHILD_NAME=Cooper

# Kokoro TTS — absolute paths inside the container
KOKORO_MODEL=/app/server/models/kokoro-v1.0.onnx
KOKORO_VOICES=/app/server/models/voices-v1.0.bin
KOKORO_VOICE=bm_lewis
KOKORO_SPEED=1.2

# Session persistence (set to 1 to enable SQLite-backed history)
PERSIST_SESSIONS=1
SESSION_DB_PATH=/app/server/sessions/sessions.db

# Optional API key — leave empty for no authentication (home/dev use)
KIDBOT_API_KEY=

# Log file path (leave empty to write to stdout only)
LOG_FILE=/app/logs/kidbot.log
